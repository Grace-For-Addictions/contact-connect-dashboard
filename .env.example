# Copy to .env (local) and set the same vars in Cloudflare Pages > Settings >
# Environment variables. All VITE_* vars are baked into the client bundle at
# build time, so they must be present when `npm run build` runs.

# Supabase project REST URL, e.g. https://abcxyz.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (safe to expose; protected by RLS)
VITE_SUPABASE_ANON_KEY=

# "true"  -> no login required; unauthenticated visitors act as a coach (v1)
# "false" -> require Supabase Auth (add a login page before flipping this)
VITE_OPEN_ACCESS=true

# ---- Edge Function secrets (set with `supabase secrets set`, NOT here) -------
# ANTHROPIC_API_KEY   required by the invoke-llm function
# LLM_MODEL           optional, defaults to claude-sonnet-5
